PORT=3001
WS_PORT=3002
NODE_ENV=development

JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

DB_PATH=./data/smart_alert.db

# Audio processing settings
AUDIO_SAMPLE_RATE=16000
AUDIO_CHANNELS=1
AUDIO_BIT_DEPTH=16
VAD_FRAME_LENGTH=30
VAD_MODE=3

# Noise suppression thresholds
NOISE_FLOOR_DB=-60
SIGNAL_THRESHOLD_DB=-30
NOISE_REDUCTION_STRENGTH=0.75

# Alert settings
ALERT_COOLDOWN_MS=2000
MAX_ALERTS_PER_MINUTE=10

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

LOG_LEVEL=info
LOG_FILE=./logs/app.log
